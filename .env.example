# ============================================
# Saudi Gold - Environment Variables
# ============================================

# Metal Price API Key (from metalpriceapi.com)
METAL_API_KEY=484e10b2ec808863d1c692d2ea2eb921

# Cron Secret - generate a random string!
# Use: openssl rand -hex 32
CRON_SECRET=your-super-secret-random-string-here

# ============================================
# Vercel KV (Required for caching)
# ============================================
# These are automatically set when you link KV in Vercel dashboard
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# ============================================
# Optional: For local development
# ============================================
# Use Upstash Redis for local testing
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
