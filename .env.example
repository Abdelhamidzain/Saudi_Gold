# Metal Price API (fallback price source) — get yours at metalpriceapi.com
METAL_API_KEY=your_metalpriceapi_key_here

# Cron Secret — choose any strong random string
CRON_SECRET=change_me_to_a_random_secret

# Neon Database URL
# احصل عليه من: console.neon.tech → Connection Details
DATABASE_URL=postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
